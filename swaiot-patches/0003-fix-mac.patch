From 5470896fac84c3a2d48f3f07e3596a0dec35c504 Mon Sep 17 00:00:00 2001
From: ghoker143 <ghoker51@protonmail.com>
Date: Fri, 13 Mar 2026 20:41:18 +0800
Subject: [PATCH 3/4] fix mac

Signed-off-by: ghoker143 <ghoker51@protonmail.com>
---
 .../dts/ipq8074-swaiot-m01mx-cpe.dts          | 24 +++++++++++++++----
 .../ipq807x/base-files/etc/board.d/02_network | 14 -----------
 .../etc/hotplug.d/firmware/11-ath11k-caldata  |  3 +++
 3 files changed, 22 insertions(+), 19 deletions(-)

diff --git a/target/linux/qualcommax/dts/ipq8074-swaiot-m01mx-cpe.dts b/target/linux/qualcommax/dts/ipq8074-swaiot-m01mx-cpe.dts
index 9697eff7de..585dec736e 100644
--- a/target/linux/qualcommax/dts/ipq8074-swaiot-m01mx-cpe.dts
+++ b/target/linux/qualcommax/dts/ipq8074-swaiot-m01mx-cpe.dts
@@ -326,11 +326,7 @@
 
 	flash@0 {
 		reg = <0>;
-		/*
-		 * Some Qualcomm bootloader paths look for the legacy compatible.
-		 */
-		linux,modalias = "m25p80", "n25q128a11";
-		compatible = "micron,n25q128a11", "jedec,spi-nor";
+		compatible = "mxicy,mx25u6435f", "jedec,spi-nor";
 		spi-max-frequency = <50000000>;
 
 		partitions {
@@ -462,6 +458,18 @@
 			partition@690000 {
 				label = "ledeinfo";
 				reg = <0x690000 0x10000>;
+
+				nvmem-layout {
+					compatible = "fixed-layout";
+					#address-cells = <1>;
+					#size-cells = <1>;
+
+					macaddr_ledeinfo_18: macaddr@18 {
+						compatible = "mac-base";
+						reg = <0x18 0x6>;
+						#nvmem-cell-cells = <1>;
+					};
+				};
 			};
 
 			partition@6a0000 {
@@ -564,18 +572,24 @@
 	status = "okay";
 	phy-handle = <&qca8075_2>;
 	label = "lan1";
+	nvmem-cells = <&macaddr_ledeinfo_18 1>;
+	nvmem-cell-names = "mac-address";
 };
 
 &dp4 {
 	status = "okay";
 	phy-handle = <&qca8075_3>;
 	label = "lan2";
+	nvmem-cells = <&macaddr_ledeinfo_18 2>;
+	nvmem-cell-names = "mac-address";
 };
 
 &dp5 {
 	status = "okay";
 	phy-handle = <&qca8081_24>;
 	label = "wan";
+	nvmem-cells = <&macaddr_ledeinfo_18 0>;
+	nvmem-cell-names = "mac-address";
 };
 
 &wifi {
diff --git a/target/linux/qualcommax/ipq807x/base-files/etc/board.d/02_network b/target/linux/qualcommax/ipq807x/base-files/etc/board.d/02_network
index 35c78d5d91..cff83ca77d 100644
--- a/target/linux/qualcommax/ipq807x/base-files/etc/board.d/02_network
+++ b/target/linux/qualcommax/ipq807x/base-files/etc/board.d/02_network
@@ -103,20 +103,6 @@ ipq807x_setup_macs()
 		lan_mac=$(macaddr_add "$wan_mac" 1)
 		label_mac="$wan_mac"
 		;;
-	swaiot,m01mx)
-		ledeinfo_part=$(
-			awk '
-				$2 == "00010000" && $4 == "\"ledeinfo\"" {
-					sub(/:$/, "", $1);
-					print "/dev/mtdblock" substr($1, 4);
-					exit;
-				}
-			' /proc/mtd
-		)
-		[ -n "$ledeinfo_part" ] && wan_mac=$(get_mac_binary "$ledeinfo_part" 0x18)
-		[ -n "$wan_mac" ] && lan_mac=$(macaddr_add "$wan_mac" 1)
-		label_mac="$wan_mac"
-		;;
 	tcl,linkhub-hh500v)
 		wan_mac=$(mtd_get_mac_binary "0:ART" 0x5e290)
 		lan_mac=$(mtd_get_mac_binary "0:ART" 0x5e296)
diff --git a/target/linux/qualcommax/ipq807x/base-files/etc/hotplug.d/firmware/11-ath11k-caldata b/target/linux/qualcommax/ipq807x/base-files/etc/hotplug.d/firmware/11-ath11k-caldata
index 157e79be21..a5654a4800 100644
--- a/target/linux/qualcommax/ipq807x/base-files/etc/hotplug.d/firmware/11-ath11k-caldata
+++ b/target/linux/qualcommax/ipq807x/base-files/etc/hotplug.d/firmware/11-ath11k-caldata
@@ -103,6 +103,9 @@ case "$FIRMWARE" in
 		;;
 	swaiot,m01mx)
 		caldata_extract "0:art" 0x1000 0x20000
+		ath11k_patch_mac $(mtd_get_mac_binary "0:art" 0x100e) 0
+		ath11k_patch_mac $(mtd_get_mac_binary "0:art" 0x1014) 1
+		ath11k_set_macflag
 		;;
 	prpl,haze|\
 	spectrum,sax1v1k)
-- 
2.53.0

